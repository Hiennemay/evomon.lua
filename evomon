function ToggleAimbot()
    aimbotEnabled = not aimbotEnabled
    CONFIG.AimEnabled = aimbotEnabled
    aimLabel.Text = "Aimbot: " .. (aimbotEnabled and "ON" or "OFF")
    aimLabel.TextColor3 = aimbotEnabled and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
    aimBtn.Text = aimbotEnabled and "ON" or "OFF"
    aimBtn.BackgroundColor3 = aimbotEnabled and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
    if not aimbotEnabled then currentTarget = nil end
    UpdateLog("Aimbot " .. (aimbotEnabled and "ON" or "OFF"))
end

function GetNearestTarget()
    local char = GetCharacter()
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local camPos = camera.CFrame.Position
    local camDir = camera.CFrame.LookVector
    local nearest = nil
    local nearestAngle = CONFIG.AimFOV
    
    for _, target in pairs(players:GetPlayers()) do
        if target ~= player then
            local tChar = target.Character
            if tChar and tChar.Parent then
                if CONFIG.TeamCheck and target.Team and player.Team and target.Team == player.Team then continue end
                local tPart = tChar:FindFirstChild(CONFIG.AimPart) or tChar:FindFirstChild("HumanoidRootPart")
                local tHum = tChar:FindFirstChild("Humanoid")
                if tPart and tHum and tHum.Health > 0 then
                    local dir = (tPart.Position - camPos).Unit
                    local angle = math.deg(math.acos(math.clamp(camDir:Dot(dir), -1, 1)))
                    if angle < nearestAngle then
                        nearestAngle = angle
                        nearest = target
                    end
                end
            end
        end
    end
    return nearest
end

