        char = player.CharacterAdded:Wait()
    end
    return char
end

-- ========== TELEPORT ==========
local function TeleportTo(position)
    if not position then return false end
    local char = GetCharacter()
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    
    local tweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Linear)
    local tween = tweenService:Create(rootPart, tweenInfo, {CFrame = CFrame.new(position)})
    tween:Play()
    tween.Completed:Wait()
    return true
end

-- ========== LẤY EVOMON GẦN NHẤT (CHỈNH SỬA) ==========
local function GetNearestEvomon()
    local char = GetCharacter()
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    
    local container = evomonContainer
    if not container then return nil end
    
    local nearest = nil
    local minDist = math.huge
    local searchRadius = 150 -- Tăng bán kính tìm kiếm
    
    local function CheckModel(model)
        if not model:IsA("Model") then return end
        local humanoid = model:FindFirstChild("Humanoid")
        local hrp = model:FindFirstChild("HumanoidRootPart")
        if humanoid and hrp and humanoid.Health > 0 then
            -- Kiểm tra xem có phải là Evomon không (tên chứa từ khóa hoặc có thuộc tính đặc biệt)
            local name = model.Name:lower()
            local isEvomon = string.find(name, "evomon") or 
                           string.find(name, "pkm") or 
                           string.find(name, "wild") or
                           string.find(name, "monster") or
                           string.find(name, "creature") or
                           (humanoid:FindFirstChild("IsEvomon") and humanoid.IsEvomon.Value == true)
            
            if isEvomon or true then -- Nếu không xác định được, vẫn coi là evomon
                local dist = (rootPart.Position - hrp.Position).Magnitude
                if dist < minDist and dist < searchRadius then
                    nearest = model
                    minDist = dist
                end
            end
        end
    end
    
    -- Duyệt trong container
    if container == workspace then
        -- Duyệt toàn bộ workspace
        for _, child in pairs(workspace:GetChildren()) do
            CheckModel(child)
        end
    else
        -- Duyệt trong container cụ thể
        for _, child in pairs(container:GetChildren()) do
            CheckModel(child)
        end
    end
    
    -- Nếu không tìm thấy, tìm kiếm sâu hơn trong các folder con
    if not nearest then
        for _, folder in pairs(workspace:GetChildren()) do
            if folder:IsA("Folder") then
                for _, child in pairs(folder:GetChildren()) do
                    CheckModel(child)
                end
            end
        end
    end
    
    if nearest then
        UpdateLog("Found Evomon: " .. nearest.Name .. " at distance " .. math.floor(minDist))
    end
    
    return nearest
end

-- ========== TẤN CÔNG EVOMON (CHỈNH SỬA) ==========
local function AttackEvomon(evomon)
    if not evomon then return false end
    local hrp = evomon:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local char = GetCharacter()
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    
    -- Teleport đến gần
    if CONFIG.AutoTeleport and (rootPart.Position - hrp.Position).Magnitude > 100 then
        TeleportTo(hrp.Position + Vector3.new(0, 3, 0))
        wait(0.2)
    end
    
    -- Quay mặt
    rootPart.CFACE = CFrame.new(rootPart.Position, hrp.Position)
    
    -- Cách 1: Simulation click chuột
    local mouse = player:GetMouse()
    if mouse then
        mouse.Button1Down:Fire()
        wait(0.05)
        mouse.Button1Up:Fire()
        UpdateLog("Attack via mouse click")
    end
    
    -- Cách 2: Gọi RemoteEvent (tên thường là Attack, Click, hoặc tương tự)
    local attackRemote = replicatedStorage:FindFirstChild("AttackEvent") or 
                         replicatedStorage:FindFirstChild("Attack") or
                         replicatedStorage:FindFirstChild("Combat") or
                         replicatedStorage:FindFirstChild("Click") or
                         replicatedStorage:FindFirstChild("Hit")
    
    if attackRemote then
        attackRemote:FireServer(evomon)
        UpdateLog("Attack via remote: " .. attackRemote.Name)
    end
    
    -- Cách 3: Gửi sự kiện bằng tool
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then
        tool:Activate()
        UpdateLog("Attack via tool: " .. tool.Name)
    end
    
    -- Cách 4: Nhấn phím Q hoặc E
    userInputService:SetKeyDown(Enum.KeyCode.Q)
    wait(0.05)
    userInputService:SetKeyUp(Enum.KeyCode.Q)
    
    wait(0.3)
    return true
end

-- ========== NÉM BALL BẮT EVOMON ==========
local function ThrowBall(evomon)
    if not evomon then return false end
    local hrp = evomon:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local char = GetCharacter()
    
    -- Tìm Ball (có thể là Pokeball, Evoball, CaptureBall)
    local ball = player.Backpack:FindFirstChild("Pokeball") or 
                 player.Backpack:FindFirstChild("PokeBall") or
                 player.Backpack:FindFirstChild("Evoball") or
                 player.Backpack:FindFirstChild("CaptureBall") or
                 char:FindFirstChild("Pokeball") or
                 char:FindFirstChild("Evoball")
    
    if not ball then
        UpdateLog("No ball found")
        return false
    end
    
    -- Equip
    if ball.Parent ~= char then
        ball.Parent = char
        wait(0.1)
    end
    
    -- Sử dụng
    local remote = ball:FindFirstChild("Activate") or 
                   ball:FindFirstChild("RemoteEvent") or
                   ball:FindFirstChild("Use") or
                   ball:FindFirstChild("Throw")
    
    if remote then
        if remote:IsA("RemoteEvent") then
            remote:FireServer(hrp.Position, evomon)
        else
            remote:Fire()
        end
        UpdateLog("Ball thrown at " .. evomon.Name)
    end
    
    wait(1)
    return true
end

-- ========== TỰ HỒI MÁU ==========
local function AutoHeal()
    local char = GetCharacter()
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    local hp = humanoid.Health
    local maxHp = humanoid.MaxHealth
    if maxHp <= 0 then return end
    
    local percent = (hp / maxHp) * 100
    
    if percent < 30 then
        local potion = player.Backpack:FindFirstChild("Potion") or 
                       player.Backpack:FindFirstChild("HealthPotion") or
                       char:FindFirstChild("Potion")
        
        if potion then
            if potion.Parent ~= char then
                potion.Parent = char
                wait(0.1)
            end
            
            local useRemote = potion:FindFirstChild("Use") or 
                             potion:FindFirstChild("RemoteEvent")
            if useRemote then
                if useRemote:IsA("RemoteEvent") then
                    useRemote:FireServer()
                else
                    useRemote:Fire()
                end
                UpdateLog("Used Potion")
            end
            wait(0.5)
        end
    end
end

-- ========== VÒNG LẶP CHÍNH ==========
local isRunning = false
local loopCoroutine = nil
local frameCounter = 0

local function MainLoop()
    UpdateLog("Main loop started - targeting Evomons")
    while isRunning do
        wait(0.05)
        frameCounter = frameCounter + 1
        
        -- Mỗi 20 frames (~1 giây) log status
        if frameCounter % 20 == 0 then
            local char = GetCharacter()
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local pos = hrp.Position
                UpdateLog("Position: " .. math.floor(pos.X) .. ", " .. math.floor(pos.Z))
            end
        end
        
        -- Auto Heal
        if CONFIG.AutoHeal then
            AutoHeal()
        end
        
        -- Auto Farm
        if CONFIG.AutoFarm then
            local evomon = GetNearestEvomon()
            if evomon then
                local humanoid = evomon:FindFirstChild("Humanoid")
                local hrp = evomon:FindFirstChild("HumanoidRootPart")
                if humanoid and hrp then
                    local hp = humanoid.Health
                    local maxHp = humanoid.MaxHealth
                    local hpPercent = (hp / maxHp) * 100
                    
                    if CONFIG.AutoCatch and hpPercent < 20 then
                        UpdateLog("Catching Evomon: " .. evomon.Name)
                        ThrowBall(evomon)
                    else
                        UpdateLog("Attacking: " .. evomon.Name .. " (HP: " .. math.floor(hpPercent) .. "%)")
                        AttackEvomon(evomon)
                    end
                end
            else
                UpdateLog("No Evomon found nearby, moving to spawn")
                local spawnPoint = workspace:FindFirstChild("SpawnLocation")
                if spawnPoint and CONFIG.AutoTeleport then
                    TeleportTo(spawnPoint.Position + Vector3.new(0, 5, 0))
                end
            end
        end
    end
end

