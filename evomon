-- ========== LOGGING ==========
local function UpdateLog(msg)
    print("[FlyScript - Make by Hiền] " .. msg)
end

-- ========== HÀM FLY ==========
local function GetCharacter()
    local char = player.Character
    if not char or not char.Parent then
        char = player.CharacterAdded:Wait()
    end
    return char
end

local function SetupFly()
    character = GetCharacter()
    humanoid = character:FindFirstChild("Humanoid")
    rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not rootPart then
        UpdateLog("Cannot find Humanoid or HumanoidRootPart")
        return false
    end
    
    -- Tạo BodyVelocity để di chuyển
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Name = "FlyBV"
    bodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = rootPart
    
    -- Tạo BodyGyro để giữ hướng
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.Name = "FlyBG"
    bodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
    bodyGyro.Parent = rootPart
    bodyGyro.CFrame = rootPart.CFrame
    
    -- Tắt trọng lực
    humanoid.PlatformStand = true
    humanoid.AutoRotate = false
    
    UpdateLog("Fly setup complete")
    return true
end

local function CleanupFly()
    if bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
    end
    if bodyGyro then
        bodyGyro:Destroy()
        bodyGyro = nil
    end
    if humanoid then
        humanoid.PlatformStand = false
        humanoid.AutoRotate = true
    end
    UpdateLog("Fly cleanup complete")
end

-- ========== TOGGLE FLY ==========
function ToggleFly()
    if flying then
        flying = false
        flyBtn.Text = "FLY: OFF"
        flyBtn.BackgroundColor3 = Color3.fromRGB(30, 150, 255)
        CleanupFly()
        UpdateLog("Fly disabled")
    else
        flying = true
        flyBtn.Text = "FLY: ON"
        flyBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        if SetupFly() then
            UpdateLog("Fly enabled - Speed: " .. currentSpeed)
        else
            flying = false
            flyBtn.Text = "FLY: OFF"
            flyBtn.BackgroundColor3 = Color3.fromRGB(30, 150, 255)
            UpdateLog("Failed to enable fly")
        end
    end
end

-- ========== UPDATE FLY MOVEMENT ==========
local function UpdateFly()
    if not flying then return end
    if not rootPart then
        character = GetCharacter()
        rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
    end
    
    if not bodyVelocity then return end
    
    -- Lấy hướng từ camera
    local cameraCFrame = camera.CFrame
    local forward = cameraCFrame.LookVector
    local right = cameraCFrame.RightVector
    local up = cameraCFrame.UpVector
    
    -- Lấy input từ bàn phím
    local moveDirection = Vector3.new(0, 0, 0)
    
    if userInputService:IsKeyDown(Enum.KeyCode.W) then
        moveDirection = moveDirection + forward
    end
    if userInputService:IsKeyDown(Enum.KeyCode.S) then
        moveDirection = moveDirection - forward
    end
    if userInputService:IsKeyDown(Enum.KeyCode.A) then
        moveDirection = moveDirection - right
    end
    if userInputService:IsKeyDown(Enum.KeyCode.D) then
        moveDirection = moveDirection + right
    end
    if userInputService:IsKeyDown(Enum.KeyCode.Space) then
        moveDirection = moveDirection + up
    end
    if userInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        moveDirection = moveDirection - up
    end
    
    -- Nếu không có input, dừng lại
    if moveDirection.Magnitude > 0 then
        moveDirection = moveDirection.Unit * currentSpeed
    else
        moveDirection = Vector3.new(0, 0, 0)
    end
    
    -- Áp dụng vận tốc
    bodyVelocity.Velocity = moveDirection
    
    -- Cập nhật hướng cho BodyGyro
    if bodyGyro then
        bodyGyro.CFrame = CFrame.new(rootPart.Position, rootPart.Position + cameraCFrame.LookVector)
    end
end

-- ========== PHÍM TẮT ==========
userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.F then
        ToggleFly()
    end
    
    -- Phím tắt điều chỉnh tốc độ
    if input.KeyCode == Enum.KeyCode.Equals or input.KeyCode == Enum.KeyCode.Plus then
        currentSpeed = math.min(CONFIG.MaxSpeed, currentSpeed + CONFIG.StepSize)
        CONFIG.FlySpeed = currentSpeed
        speedLabel.Text = "Speed: " .. currentSpeed
        speedSlider.Text = tostring(currentSpeed)
        speedDisplay.Text = tostring(currentSpeed)
        UpdateLog("Speed increased to: " .. currentSpeed)
    end
    
    if input.KeyCode == Enum.KeyCode.Minus then
        currentSpeed = math.max(CONFIG.MinSpeed, currentSpeed - CONFIG.StepSize)
        CONFIG.FlySpeed = currentSpeed
        speedLabel.Text = "Speed: " .. currentSpeed
        speedSlider.Text = tostring(currentSpeed)
        speedDisplay.Text = tostring(currentSpeed)
        UpdateLog("Speed decreased to: " .. currentSpeed)
    end
end)

-- ========== LOOP CHÍNH ==========
runService.RenderStepped:Connect(function()
    UpdateFly()
end)

-- ========== XỬ LÝ KHI CHARACTER CHẾT ==========
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = character:FindFirstChild("Humanoid")
    rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if flying then
        wait(0.5)
        SetupFly()
    end
end)

-- ========== KHỞI TẠO ==========
UpdateLog("Fly script loaded! Press F to toggle fly")
UpdateLog("Use WASD to move, Space up, Shift down")
UpdateLog("Use + and - keys to adjust speed")

-- ========== KÉO THẢ GUI ==========
local dragging = false
local dragStart = nil
local startPos = nil

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

mainFrame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

userInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

print("[DeltaX] Fly script by Hiền loaded successfully!")
