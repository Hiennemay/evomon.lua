-- ===== ESP =====
function CreateESP(targetPlr)
    if not espEnabled or targetPlr == player then return end
    local char = targetPlr.Character
    if not char or not char.Parent then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end
    
    if not espFolder then
        espFolder = Instance.new("Folder")
        espFolder.Name = "ESP_Folder"
        espFolder.Parent = screenGui
    end
    
    local existing = espFolder:FindFirstChild(targetPlr.Name)
    if existing then existing:Destroy() end
    
    local frame = Instance.new("Frame")
    frame.Name = targetPlr.Name
    frame.Size = UDim2.new(0, 6, 0, 60)
    frame.BackgroundColor3 = CONFIG.ESPColor
    frame.BackgroundTransparency = 0.6
    frame.BorderSizePixel = 1
    frame.BorderColor3 = Color3.fromRGB(255, 255, 255)
    frame.Parent = espFolder
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(0, 120, 0, 16)
    nameLabel.Position = UDim2.new(0.5, -60, 0, -18)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = targetPlr.Name
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextStrokeTransparency = 0.5
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.Parent = frame
    
    local healthBar = Instance.new("Frame")
    healthBar.Size = UDim2.new(0, 60, 0, 8)
    healthBar.Position = UDim2.new(0.5, -30, 0, -8)
    healthBar.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    healthBar.BorderSizePixel = 1
    healthBar.BorderColor3 = Color3.fromRGB(0, 0, 0)
    healthBar.Parent = frame
    
    local healthFill = Instance.new("Frame")
    healthFill.Size = UDim2.new(1, 0, 1, 0)
    healthFill.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    healthFill.BorderSizePixel = 0
    healthFill.Parent = healthBar
    
    local distLabel = Instance.new("TextLabel")
    distLabel.Size = UDim2.new(0, 60, 0, 14)
    distLabel.Position = UDim2.new(0.5, -30, 0, 62)
    distLabel.BackgroundTransparency = 1
    distLabel.Text = ""
    distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    distLabel.TextScaled = true
    distLabel.Font = Enum.Font.Code
    distLabel.TextStrokeTransparency = 0.5
    distLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    distLabel.Parent = frame
    
    espObjects[targetPlr] = {
        Frame = frame,
        HealthBar = healthFill,
        DistLabel = distLabel,
        Character = char
    }
end

function UpdateESP()
    if not espEnabled then ClearESP(); return end
    local localChar = GetCharacter()
    local localRoot = localChar:FindFirstChild("HumanoidRootPart")
    if not localRoot then return end
    
    for target, data in pairs(espObjects) do
        if not target or not target.Character or not target.Character.Parent then
            if data.Frame then data.Frame:Destroy() end
            espObjects[target] = nil
        end
    end
    
    for _, target in pairs(players:GetPlayers()) do
        if target ~= player then
            local char = target.Character
            if char and char.Parent then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")
                if hrp and hum then
                    if not espObjects[target] then CreateESP(target) end
                    local data = espObjects[target]
                    if data and data.Frame then
                        local pos, onScreen = camera:WorldToScreenPoint(hrp.Position)
                        if onScreen then
                            data.Frame.Visible = true
                            data.Frame.Position = UDim2.new(0, pos.X - 3, 0, pos.Y - 30)
                            local dist = (localRoot.Position - hrp.Position).Magnitude
                            if CONFIG.ShowDistance and dist < CONFIG.ESPDistance then
                                data.DistLabel.Text = math.floor(dist) .. "m"
                                data.DistLabel.Visible = true
                            else
                                data.DistLabel.Visible = false
                            end
                            local hp = hum.Health / hum.MaxHealth
                            data.HealthBar.Size = UDim2.new(hp, 0, 1, 0)
                            data.HealthBar.BackgroundColor3 = hp > 0.6 and Color3.fromRGB(0, 255, 0) or hp > 0.3 and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(255, 0, 0)
                            data.Frame.BackgroundColor3 = (target.Team and player.Team and target.Team == player.Team) and Color3.fromRGB(0, 255, 255) or Color3.fromRGB(255, 0, 0)
                        else
                            data.Frame.Visible = false
                        end
                    end
                end
            end
        end
    end
end

