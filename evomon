local function UpdateESP()
    if not espEnabled then
        ClearESP()
        return
    end
    
    local localChar = GetCharacter()
    local localRoot = localChar:FindFirstChild("HumanoidRootPart")
    if not localRoot then return end
    
    for target, data in pairs(espObjects) do
        if not target or not target.Character or not target.Character.Parent then
            if data.Frame then
                data.Frame:Destroy()
            end
            espObjects[target] = nil
        end
    end
    
    for _, target in pairs(players:GetPlayers()) do
        if target ~= player then
            local char = target.Character
            if char and char.Parent then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")
                if hrp and hum then
                    if not espObjects[target] then
                        CreateESP(target)
                    end
                    
                    local data = espObjects[target]
                    if data and data.Frame then
                        local pos, onScreen = camera:WorldToScreenPoint(hrp.Position)
                        if onScreen then
                            data.Frame.Visible = true
                            data.Frame.Position = UDim2.new(0, pos.X - 3, 0, pos.Y - 30)
                            
                            local dist = (localRoot.Position - hrp.Position).Magnitude
                            if CONFIG.ShowDistance and dist < CONFIG.ESPDistance then
                                data.DistLabel.Text = math.floor(dist) .. "m"
                                data.DistLabel.Visible = true
                            else
                                data.DistLabel.Visible = false
                            end
                            
                            local health = hum.Health
                            local maxHealth = hum.MaxHealth
                            local healthPercent = health / maxHealth
                            data.HealthBar.Size = UDim2.new(healthPercent, 0, 1, 0)
                            
                            if healthPercent > 0.6 then
                                data.HealthBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                            elseif healthPercent > 0.3 then
                                data.HealthBar.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
                            else
                                data.HealthBar.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                            end
                            
                            if target.Team and player.Team and target.Team == player.Team then
                                data.Frame.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
                            else
                                data.Frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                            end
                        else
                            data.Frame.Visible = false
                        end
                    end
                end
            end
        end
    end
end

local function ClearESP()
    if espFolder then
        espFolder:Destroy()
        espFolder = nil
    end
    espObjects = {}
end

-- ========== PHÍM TẮT ==========
userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.F then
        ToggleFly()
    end
    
    if input.KeyCode == Enum.KeyCode.G then
        ToggleSpeedHack()
    end
    
    if input.KeyCode == Enum.KeyCode.Z then
        espEnabled = not espEnabled
        CONFIG.ESPEnabled = espEnabled
        espLabel.Text = "ESP: " .. (espEnabled and "ON" or "OFF")
        espLabel.TextColor3 = espEnabled and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        espBtn.Text = espEnabled and "ON" or "OFF"
        espBtn.BackgroundColor3 = espEnabled and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
        if not espEnabled then
            ClearESP()
        end
        UpdateLog("ESP " .. (espEnabled and "ON" or "OFF"))
    end
    
    -- Điều chỉnh tốc độ không giới hạn
    if input.KeyCode == Enum.KeyCode.Equals or input.KeyCode == Enum.KeyCode.Plus then
        currentSpeed = currentSpeed + CONFIG.StepSize
        CONFIG.FlySpeed = currentSpeed
        CONFIG.WalkSpeed = currentSpeed
        speedSlider.Text = tostring(currentSpeed)
        speedSliderLabel.Text = "Speed: " .. currentSpeed
        if speedHack then
            local char = GetCharacter()
            local hum = char:FindFirstChild("Humanoid")
            if hum then
                hum.WalkSpeed = currentSpeed
            end
        end
        UpdateLog("Speed increased to: " .. currentSpeed .. " (Unlimited)")
    end
    
    if input.KeyCode == Enum.KeyCode.Minus then
        currentSpeed = math.max(CONFIG.MinSpeed, currentSpeed - CONFIG.StepSize)
        CONFIG.FlySpeed = currentSpeed
        CONFIG.WalkSpeed = currentSpeed
        speedSlider.Text = tostring(currentSpeed)
        speedSliderLabel.Text = "Speed: " .. currentSpeed
        if speedHack then
            local char = GetCharacter()
            local hum = char:FindFirstChild("Humanoid")
            if hum then
                hum.WalkSpeed = currentSpeed
            end
        end
        UpdateLog("Speed decreased to: " .. currentSpeed)
    end
end)

