-- ========== FIND REMOTE EVENTS ==========
local function FindRemoteEvents()
    local found = {}
    for _, service in pairs({replicatedStorage, game:GetService("ReplicatedFirst")}) do
        for _, child in pairs(service:GetChildren()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                table.insert(found, child.Name)
            end
        end
    end
    return found
end

local remoteNames = FindRemoteEvents()
UpdateLog("Found remotes: " .. table.concat(remoteNames, ", "))

-- ========== FIND MONSTER CONTAINER ==========
local function FindMonsterContainer()
    local possible = {"Monsters", "NPCs", "Mobs", "Creatures", "Enemies", "Wild"}
    for _, name in ipairs(possible) do
        local container = workspace:FindFirstChild(name)
        if container then
            UpdateLog("Found monster container: " .. name)
            return container
        end
    end
    -- Scan entire workspace
    for _, child in pairs(workspace:GetChildren()) do
        if child:IsA("Model") and child:FindFirstChild("Humanoid") then
            local container = child.Parent
            if container and container ~= workspace then
                UpdateLog("Found monster parent: " .. container.Name)
                return container
            end
        end
    end
    return nil
end

local monsterContainer = FindMonsterContainer()

-- ========== GET CHARACTER ==========
local function GetCharacter()
    local char = player.Character
    if not char or not char.Parent then
        char = player.CharacterAdded:Wait()
    end
    return char
end

-- ========== TELEPORT ==========
local function TeleportTo(position)
    if not position then return false end
    local char = GetCharacter()
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    
    local tweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Linear)
    local tween = tweenService:Create(rootPart, tweenInfo, {CFrame = CFrame.new(position)})
    tween:Play()
    tween.Completed:Wait()
    return true
end

-- ========== GET NEAREST MONSTER (IMPROVED) ==========
local function GetNearestMonster()
    local char = GetCharacter()
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    
    local container = monsterContainer
    if not container then return nil end
    
    local nearest = nil
    local minDist = math.huge
    
    for _, child in pairs(container:GetChildren()) do
        if child:IsA("Model") then
            local humanoid = child:FindFirstChild("Humanoid")
            local hrp = child:FindFirstChild("HumanoidRootPart")
            if humanoid and hrp and humanoid.Health > 0 then
                local dist = (rootPart.Position - hrp.Position).Magnitude
                if dist < minDist and dist < 80 then
                    nearest = child
                    minDist = dist
                end
            end
        end
    end
    
    if not nearest then
        -- Scan entire workspace
        for _, child in pairs(workspace:GetChildren()) do
            if child:IsA("Model") and child ~= char then
                local humanoid = child:FindFirstChild("Humanoid")
                local hrp = child:FindFirstChild("HumanoidRootPart")
                if humanoid and hrp and humanoid.Health > 0 then
                    local dist = (rootPart.Position - hrp.Position).Magnitude
                    if dist < minDist and dist < 80 then
                        nearest = child
                        minDist = dist
                    end
                end
            end
        end
    end
    
    return nearest
end

-- ========== ATTACK USING MULTIPLE METHODS ==========
local function AttackMonster(monster)
    if not monster then return false end
    local hrp = monster:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local char = GetCharacter()
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    
    -- Teleport closer
    if CONFIG.AutoTeleport and (rootPart.Position - hrp.Position).Magnitude > 120 then
        TeleportTo(hrp.Position + Vector3.new(0, 3, 0))
        wait(0.2)
    end
    
    -- Face monster
    rootPart.CFrame = CFrame.new(rootPart.Position, hrp.Position)
    
    -- Method 1: Mouse click simulation
    local mouse = player:GetMouse()
    if mouse then
        mouse.Button1Down:Fire()
        wait(0.05)
        mouse.Button1Up:Fire()
        UpdateLog("Attack via mouse click")
    end
    
    -- Method 2: RemoteEvent call
    local attackRemote = replicatedStorage:FindFirstChild("AttackEvent") or 
                         replicatedStorage:FindFirstChild("Attack") or
                         replicatedStorage:FindFirstChild("Combat")
    if attackRemote then
        attackRemote:FireServer(monster)
        UpdateLog("Attack via remote: " .. attackRemote.Name)
    end
    
    -- Method 3: Tool activation
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then
        tool:Activate()
        UpdateLog("Attack via tool: " .. tool.Name)
    end
    
    -- Method 4: Key press (Q or E)
    userInputService:SetKeyDown(Enum.KeyCode.Q)
    wait(0.05)
    userInputService:SetKeyUp(Enum.KeyCode.Q)
    
    wait(0.3)
    return true
end

-- ========== THROW POKEBALL ==========
local function ThrowPokeball(monster)
    if not monster then return false end
    local hrp = monster:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local char = GetCharacter()
    
    -- Find Pokeball
    local pokeball = player.Backpack:FindFirstChild("Pokeball") or 
                     player.Backpack:FindFirstChild("PokeBall") or
                     char:FindFirstChild("Pokeball")
    
    if not pokeball then
        UpdateLog("No Pokeball found")
        return false
    end
    
    -- Equip
    if pokeball.Parent ~= char then
        pokeball.Parent = char
        wait(0.1)
    end
    
    -- Use
    local remote = pokeball:FindFirstChild("Activate") or 
                   pokeball:FindFirstChild("RemoteEvent") or
                   pokeball:FindFirstChild("Use")
    
    if remote then
        if remote:IsA("RemoteEvent") then
            remote:FireServer(hrp.Position, monster)
        else
            remote:Fire()
        end
        UpdateLog("Pokeball thrown")
    end
    
    wait(1)
    return true
end

-- ========== AUTO HEAL ==========
local function AutoHeal()
    local char = GetCharacter()
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    local hp = humanoid.Health
    local maxHp = humanoid.MaxHealth
    if maxHp <= 0 then return end
    
    local percent = (hp / maxHp) * 100
    
    if percent < 30 then
        local potion = player.Backpack:FindFirstChild("Potion") or 
                       player.Backpack:FindFirstChild("HealthPotion") or
                       char:FindFirstChild("Potion")
        
        if potion then
            if potion.Parent ~= char then
                potion.Parent = char
                wait(0.1)
            end
            
            local useRemote = potion:FindFirstChild("Use") or 
                             potion:FindFirstChild("RemoteEvent")
            if useRemote then
                if useRemote:IsA("RemoteEvent") then
                    useRemote:FireServer()
                else
                    useRemote:Fire()
                end
                UpdateLog("Used Potion")
            end
            wait(0.5)
        end
    end
end

-- ========== MAIN LOOP (IMPROVED) ==========
local isRunning = false
local loopCoroutine = nil
local frameCounter = 0

local function MainLoop()
    UpdateLog("Main loop started")
    while isRunning do
        wait(0.05)
        frameCounter = frameCounter + 1
        
        -- Every 20 frames (~1 second) log status
        if frameCounter % 20 == 0 then
            local char = GetCharacter()
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local pos = hrp.Position
                UpdateLog("Position: " .. math.floor(pos.X) .. ", " .. math.floor(pos.Z))
            end
        end
        
        -- Auto Heal
        if CONFIG.AutoHeal then
            AutoHeal()
        end
        
        -- Auto Farm
        if CONFIG.AutoFarm then
            local monster = GetNearestMonster()
            if monster then
                local humanoid = monster:FindFirstChild("Humanoid")
                local hrp = monster:FindFirstChild("HumanoidRootPart")
                if humanoid and hrp then
                    local hp = humanoid.Health
                    local maxHp = humanoid.MaxHealth
                    local hpPercent = (hp / maxHp) * 100
                    
                    if CONFIG.AutoCatch and hpPercent < 20 then
                        UpdateLog("Catching monster: " .. monster.Name)
                        ThrowPokeball(monster)
                    else
                        UpdateLog("Attacking: " .. monster.Name .. " (HP: " .. math.floor(hpPercent) .. "%)")
                        AttackMonster(monster)
                    end
                end
            else
                UpdateLog("No monster found, moving to spawn")
                local spawnPoint = workspace:FindFirstChild("SpawnLocation")
                if spawnPoint and CONFIG.AutoTeleport then
                    TeleportTo(spawnPoint.Position + Vector3.new(0, 5, 0))
                end
            end
        end
    end
end

