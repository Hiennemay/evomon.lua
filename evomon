-- TELEPORT FUNCTION
local function TeleportTo(position)
    if not position then return end
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    local tweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Linear)
    local tween = tweenService:Create(rootPart, tweenInfo, {CFrame = CFrame.new(position)})
    tween:Play()
    tween.Completed:Wait()
end

-- GET NEAREST MONSTER
local function GetNearestMonster()
    local monsters = workspace:FindFirstChild("Monsters") or workspace:FindFirstChild("NPCs")
    if not monsters then return nil end
    local character = player.Character
    if not character then return nil end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    
    local nearest = nil
    local minDist = math.huge
    
    for _, child in pairs(monsters:GetChildren()) do
        if child:IsA("Model") and child:FindFirstChild("Humanoid") and child:FindFirstChild("HumanoidRootPart") then
            local hp = child.Humanoid.Health
            if hp > 0 then
                local dist = (rootPart.Position - child.HumanoidRootPart.Position).Magnitude
                if dist < minDist and dist < 50 then
                    nearest = child
                    minDist = dist
                end
            end
        end
    end
    return nearest
end

-- ATTACK MONSTER
local function AttackMonster(monster)
    if not monster then return end
    local hrp = monster:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local character = player.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    if CONFIG.AutoTeleport and (rootPart.Position - hrp.Position).Magnitude > 150 then
        TeleportTo(hrp.Position + Vector3.new(0, 5, 0))
        wait(0.3)
    end
    
    rootPart.CFrame = CFrame.new(rootPart.Position, hrp.Position)
    
    local mouse = player:GetMouse()
    if mouse then
        mouse.Button1Down:Fire()
        wait(0.1)
        mouse.Button1Up:Fire()
    end
    
    local attackEvent = game:GetService("ReplicatedStorage"):FindFirstChild("AttackEvent")
    if attackEvent then
        attackEvent:FireServer(monster)
    end
    
    wait(0.5)
end

-- THROW POKEBALL
local function ThrowPokeball(monster)
    if not monster then return end
    local hrp = monster:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local pokeballItem = player.Backpack:FindFirstChild("Pokeball") or player.Character:FindFirstChild("Pokeball")
    if not pokeballItem then return end
    
    local tool = pokeballItem
    if tool and tool.Parent ~= player.Character then
        tool.Parent = player.Character
        wait(0.1)
    end
    
    if tool and tool:FindFirstChild("Activate") then
        tool.Activate:FireServer(hrp.Position)
    elseif tool and tool:FindFirstChild("RemoteEvent") then
        tool.RemoteEvent:FireServer(monster)
    end
    
    wait(1)
end

-- AUTO HEAL
local function AutoHeal()
    local character = player.Character
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    local hp = humanoid.Health
    local maxHp = humanoid.MaxHealth
    local percent = (hp / maxHp) * 100
    
    if percent < 30 then
        local potion = player.Backpack:FindFirstChild("Potion") or player.Character:FindFirstChild("Potion")
        if potion then
            if potion.Parent ~= player.Character then
                potion.Parent = player.Character
                wait(0.1)
            end
            if potion:FindFirstChild("Use") then
                potion.Use:FireServer()
            elseif potion:FindFirstChild("RemoteEvent") then
                potion.RemoteEvent:FireServer()
            end
            wait(0.5)
        end
    end
end

-- MAIN LOOP
local function MainLoop()
    while isRunning do
        wait(0.1)
        local character = player.Character
        if not character then continue end
        
        if CONFIG.AutoHeal then
            AutoHeal()
        end
        
        if CONFIG.AutoFarm then
            local monster = GetNearestMonster()
            if monster then
                local hrp = monster:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local hp = monster.Humanoid.Health
                    local maxHp = monster.Humanoid.MaxHealth
                    local hpPercent = (hp / maxHp) * 100
                    
                    if CONFIG.AutoCatch and hpPercent < 20 then
                        ThrowPokeball(monster)
                    else
                        AttackMonster(monster)
                    end
                end
            else
                local spawnPoint = workspace:FindFirstChild("SpawnLocation")
                if spawnPoint and CONFIG.AutoTeleport then
                    TeleportTo(spawnPoint.Position + Vector3.new(0, 5, 0))
                end
            end
        end
    end
end

-- START BUTTON EVENT
startBtn.MouseButton1Click:Connect(function()
    if isRunning then
        isRunning = false
        startBtn.Text = "START SCRIPT"
        startBtn.BackgroundColor3 = Color3.fromRGB(30, 100, 200)
        print("[DeltaX] Script stopped")
    else
        isRunning = true
        startBtn.Text = "STOP SCRIPT"
        startBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        print("[DeltaX] Script started")
        if loopCoroutine then
            loopCoroutine = nil
        end
        loopCoroutine = coroutine.wrap(MainLoop)
        loopCoroutine()
    end
end)

