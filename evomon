-- ========== TÌM REMOTE EVENTS ==========
local function FindRemoteEvents()
    local found = {}
    for _, service in pairs({replicatedStorage, game:GetService("ReplicatedFirst")}) do
        for _, child in pairs(service:GetChildren()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                table.insert(found, child.Name)
            end
        end
    end
    return found
end

local remoteNames = FindRemoteEvents()
UpdateLog("Found remotes: " .. table.concat(remoteNames, ", "))

-- ========== TÌM EVOMON (KHÔNG PHẢI MONSTER) ==========
local function FindEvomonContainer()
    -- Evomon thường nằm trực tiếp trong workspace hoặc trong folder "Evomons"
    local possible = {"Evomons", "Evomon", "WildEvomons", "Pokemons", "Creatures"}
    
    for _, name in ipairs(possible) do
        local container = workspace:FindFirstChild(name)
        if container then
            UpdateLog("Found Evomon container: " .. name)
            return container
        end
    end
    
    -- Duyệt toàn bộ workspace tìm model có chứa "Evomon" hoặc có Humanoid
    local evomonList = {}
    for _, child in pairs(workspace:GetChildren()) do
        if child:IsA("Model") then
            local name = child.Name:lower()
            if string.find(name, "evomon") or string.find(name, "pkm") or string.find(name, "wild") then
                local humanoid = child:FindFirstChild("Humanoid")
                if humanoid then
                    table.insert(evomonList, child)
                    UpdateLog("Found Evomon: " .. child.Name)
                end
            end
        end
    end
    
    -- Nếu tìm thấy evomon riêng lẻ, trả về workspace (duyệt toàn bộ)
    if #evomonList > 0 then
        UpdateLog("Found " .. #evomonList .. " Evomons in workspace")
        return workspace
    end
    
    -- Duyệt tất cả folder con trong workspace
    for _, child in pairs(workspace:GetChildren()) do
        if child:IsA("Folder") or child:IsA("Model") then
            for _, subChild in pairs(child:GetChildren()) do
                if subChild:IsA("Model") then
                    local humanoid = subChild:FindFirstChild("Humanoid")
                    if humanoid then
                        UpdateLog("Found Evomon in folder: " .. child.Name .. " -> " .. subChild.Name)
                        return child
                    end
                end
            end
        end
    end
    
    return nil
end

local evomonContainer = FindEvomonContainer()
UpdateLog("Evomon container set to: " .. (evomonContainer and evomonContainer.Name or "nil"))

